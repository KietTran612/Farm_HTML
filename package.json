{
  "name": "farm-html",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File ./run_dev.ps1",
    "build": "tsc && vite build",
    "svg:optimize": "svgo -f src/assets/crops/source -o src/assets/crops/optimized --config svgo.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "crop:vtracer:setup": "powershell -ExecutionPolicy Bypass -File ./scripts/vtracer/setup-vtracer.ps1",
    "crop:vtracer:check": "node scripts/vtracer/check-vtracer.mjs",
    "crop:vtracer:convert": "node scripts/vtracer/convert-crop.mjs",
    "crop:vtracer:batch": "node scripts/vtracer/convert-crop-batch.mjs",
    "crop:vtracer:review": "node scripts/vtracer/review-crop-candidates.mjs",
    "crop:vtracer:inline": "node scripts/vtracer/prepare-inline-svg.mjs",
    "crop:vtracer:clear": "node scripts/vtracer/cleanup.mjs"
  },
  "devDependencies": {
    "@vitest/ui": "^3.2.4",
    "jsdom": "^26.1.0",
    "sass": "^1.89.2",
    "svgo": "^4.0.1",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
